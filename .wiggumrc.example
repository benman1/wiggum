# .wiggumrc - Wiggum configuration
# Place in project root or $HOME

# Verification steps (run in order, waterfall style)
# Each "verify" line is a shell command. If it fails, Claude is asked to fix it.
# Each "autofix" line runs the command first (letting it self-correct, e.g. ruff --fix),
# then re-runs it to check. Only escalates to Claude if it still fails.

# --- Example: TypeScript/Node project ---
# verify = npm run type-check
# verify = npm test
# verify = npm run build
# autofix = npm run lint -- --fix

# --- Example: Python project ---
# autofix = ruff format app tests scripts && ruff check --fix app tests scripts
# verify = pytest

# Benchmark scripts (optional) — run after each iteration, output fed to Claude.
# Purely informational: helps Claude see if changes are improving metrics.
# benchmark = ./scripts/measure_bundle_size.sh
# benchmark = npx lighthouse http://localhost:3000 --output json --quiet | jq '.categories.performance.score'

# Max implementation iterations — stops early if all tasks complete or stalled (default: 3)
max_iterations = 3

# Max retries per validation cycle (default: 5)
max_validation_retries = 5
